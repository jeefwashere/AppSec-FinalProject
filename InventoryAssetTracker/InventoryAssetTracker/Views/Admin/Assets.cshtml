@{
    ViewData["Title"] = "Admin - Assets";
}

<style>
    .admin-page {
        font-family: Arial, sans-serif;
    }

    .admin-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
    }

    .admin-title {
        margin: 0;
        color: #1f2937;
        font-size: 2rem;
        font-weight: 700;
    }

    .back-button,
    .action-button {
        padding: 10px 18px;
        background: #4a90e2;
        color: white;
        text-decoration: none;
        border-radius: 8px;
        border: none;
        cursor: pointer;
        font-size: 14px;
        font-weight: 600;
        transition: 0.2s;
    }

    .back-button:hover,
    .action-button:hover {
        background-color: #357bd8;
        color: white;
    }

    .delete-button {
        background: #dc3545;
    }

        .delete-button:hover {
            background: #bb2d3b;
        }

    .admin-table-wrapper {
        background: white;
        border-radius: 14px;
        box-shadow: 0 4px 14px rgba(0, 0, 0, 0.08);
        overflow: hidden;
    }

    .admin-table {
        width: 100%;
        border-collapse: collapse;
    }

    .admin-table th,
    .admin-table td {
        padding: 18px 18px;
        border-bottom: 1px solid #e5e7eb;
        text-align: left;
        vertical-align: middle;
    }

    .admin-table th {
        background-color: #f8fafc;
        font-weight: 700;
    }

    .admin-table tr:last-child td {
        border-bottom: none;
    }

    .modern-input {
        width: 100%;
        max-width: 220px;
        padding: 10px 12px;
        border: 1px solid #cbd5e1;
        border-radius: 8px;
        font-size: 14px;
        outline: none;
        transition: 0.2s;
    }

    .modern-input:focus {
        border-color: #4a90e2;
        box-shadow: 0 0 0 3px rgba(74,144,226,0.15);
    }

    .actions-cell {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .status-message {
        margin-top: 20px;
        padding: 14px;
        border-radius: 10px;
        display: none;
        font-weight: 500;
    }

    .modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(15, 23, 42, 0.45);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 1000;
    }

    .modal-box {
        width: 100%;
        max-width: 420px;
        background: white;
        border-radius: 14px;
        box-shadow: 0 12px 30px rgba(0, 0, 0, 0.18);
        padding: 24px;
    }

    .modal-title {
        margin: 0 0 10px 0;
        color: #1f2937;
        font-size: 1.3rem;
        font-weight: 700;
    }

    .modal-text {
        margin: 0 0 18px 0;
        color: #4b5563;
        line-height: 1.5;
    }

    .modal-actions {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
    }

    .cancel-button {
        background: #6b7280;
    }

    .cancel-button:hover {
        background: #4b5563;
    }

    .danger-button {
        background: #dc3545;
    }

    .danger-button:hover {
        background: #bb2d3b;
    }

</style>

<div class="admin-page">

    <div class="admin-header">
        <h2 class="admin-title">All Assets</h2>

        <a asp-controller="Admin" asp-action="Index" class="back-button">
            Back
        </a>
    </div>

    <div class="admin-table-wrapper">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Asset ID</th>
                    <th>Asset Name</th>
                    <th>Description</th>
                    <th>Quantity</th>
                    <th>Owner</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="assetsTableBody"></tbody>
        </table>
    </div>

    <div id="statusMessage" class="status-message"></div>

    <div id="deleteConfirmModal" class="modal-overlay">
        <div class="modal-box">
            <h3 class="modal-title">Delete Asset</h3>
            <p id="deleteConfirmText" class="modal-text"></p>

            <div class="modal-actions">
                <button type="button" class="action-button danger-button" id="confirmDeleteButton">Delete</button>
                <button type="button" class="action-button cancel-button" onclick="closeDeleteModal()">Cancel</button>
            </div>
        </div>
    </div>
</div>

<script>

    let pendingDeleteAssetId = null;

    function openDeleteModal(assetId, assetName) {
        pendingDeleteAssetId = assetId;

        const text = document.getElementById("deleteConfirmText");
        text.textContent = `Are you sure you want to delete asset "${assetName}"? This action cannot be undone.`;

        const modal = document.getElementById("deleteConfirmModal");
        modal.style.display = "flex";
    }

    function closeDeleteModal() {
        pendingDeleteAssetId = null;
        document.getElementById("deleteConfirmModal").style.display = "none";
    }

    async function confirmDeleteAsset() {
        if (pendingDeleteAssetId === null) {
            return;
        }

        const response = await fetch(`/api/admin/assets/${pendingDeleteAssetId}`, {
            method: "DELETE"
        });

        const result = await response.json();
        showMessage(result.message || "Delete finished.", response.ok);

        closeDeleteModal();

        if (response.ok) {
            loadAssets();
        }
    }

    function showMessage(message, isSuccess) {
        const box = document.getElementById("statusMessage");
        box.textContent = message;
        box.style.display = "block";
        box.style.backgroundColor = isSuccess ? "#e8f5e9" : "#fdecea";
        box.style.color = isSuccess ? "#2e7d32" : "#b71c1c";
        box.style.border = isSuccess
            ? "1px solid #81c784"
            : "1px solid #ef9a9a";
    }

    async function loadAssets() {
        const body = document.getElementById("assetsTableBody");
        body.innerHTML = "";

        const response = await fetch("/api/admin/assets");

        if (!response.ok) {
            body.innerHTML = `<tr><td colspan="6">Failed to load assets.</td></tr>`;
            return;
        }

        const assets = await response.json();

        assets.forEach(asset => {
            const row = document.createElement("tr");

            row.innerHTML = `
                    <td>${asset.assetId}</td>
                    <td><input class="modern-input" value="${asset.assetName}" id="assetName-${asset.assetId}" /></td>
                    <td><input class="modern-input" value="${asset.description}" id="description-${asset.assetId}" /></td>
                    <td><input class="modern-input" type="number" min="0" value="${asset.quantity}" id="quantity-${asset.assetId}" /></td>
                    <td>${asset.owner}</td>
                    <td>
                        <div class="actions-cell">
                            <button class="action-button" onclick="updateAsset(${asset.assetId})">Save</button>
                                <button class="action-button delete-button" onclick="openDeleteModal(${asset.assetId}, '${asset.assetName.replace(/'/g, "\\'")}')">Delete</button>
                        </div>
                    </td>
                `;

            body.appendChild(row);
        });
    }

    async function updateAsset(assetId) {
        const payload = {
            assetName: document.getElementById(`assetName-${assetId}`).value,
            description: document.getElementById(`description-${assetId}`).value,
            quantity: parseInt(document.getElementById(`quantity-${assetId}`).value)
        };

        const response = await fetch(`/api/admin/assets/${assetId}`, {
            method: "PUT",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload)
        });

        const result = await response.json();
        showMessage(result.message || "Update finished.", response.ok);

        if (response.ok) {
            loadAssets();
        }
    }

    window.onload = function () {
        document.getElementById("confirmDeleteButton").addEventListener("click", confirmDeleteAsset);
        loadAssets();
    };
</script>