@model List<InventoryAssetTracker.DTOs.AdminAssetResponseDTO>

@{
    ViewData["Title"] = "All Assets";
}

<style>
    .admin-page {
        font-family: Arial, sans-serif;
    }

    .admin-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .admin-title {
        margin: 0;
        color: #333;
    }

    .back-button {
        padding: 10px 16px;
        background: #4a90e2;
        color: white;
        text-decoration: none;
        border-radius: 6px;
    }

        .back-button:hover {
            background-color: #357bd8;
            color: white;
        }

    .admin-table {
        width: 100%;
        border-collapse: collapse;
        background: white;
    }

        .admin-table th,
        .admin-table td {
            padding: 12px;
            border-bottom: 1px solid #ddd;
            text-align: left;
        }

        .admin-table th {
            background-color: #f5f6f8;
        }

    .empty-message {
        margin-top: 20px;
        color: #666;
    }
</style>

<div class="admin-page">

    <!-- HEADER -->
    <div class="admin-header">
        <h2 class="admin-title">All Assets</h2>

        <a asp-controller="Admin" asp-action="Index" class="back-button">
            Back
        </a>
    </div>

    <!-- TABLE -->
    @if (Model != null && Model.Any())
    {
        <table class="admin-table">
            <thead>
                <tr>
                    <th width="200">Asset Name</th>
                    <th width="300">Description</th>
                    <th width="100">Quantity</th>
                    <th width="200">Owner</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var asset in Model)
                {
                    <tr>
                        <td>@asset.AssetName</td>
                        <td>@asset.Description</td>
                        <td>@asset.Quantity</td>
                        <td>@asset.OwnerUsername</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p class="empty-message">
            No assets found.
        </p>
    }

</div>