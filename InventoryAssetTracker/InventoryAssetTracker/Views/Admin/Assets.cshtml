@{
    ViewData["Title"] = "Admin - Assets";
}

<style>
    .admin-page {
        font-family: Arial, sans-serif;
    }

    .admin-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .admin-title {
        margin: 0;
        color: #333;
    }

    .back-button {
        padding: 10px 16px;
        background: #4a90e2;
        color: white;
        text-decoration: none;
        border-radius: 6px;
    }

        .back-button:hover {
            background-color: #357bd8;
            color: white;
        }

    .admin-table {
        width: 100%;
        border-collapse: collapse;
        background: white;
    }

        .admin-table th,
        .admin-table td {
            padding: 12px;
            border-bottom: 1px solid #ddd;
            text-align: left;
        }

        .admin-table th {
            background-color: #f5f6f8;
        }
</style>

<div class="admin-page">

    <div class="admin-header">
        <h2 class="admin-title">All Assets</h2>

        <a asp-controller="Admin" asp-action="Index" class="back-button">
            Back
        </a>
    </div>

    <table class="admin-table">
        <thead>
            <tr>
                <th width="120">Asset ID</th>
                <th width="200">Asset Name</th>
                <th width="300">Description</th>
                <th width="120">Quantity</th>
                <th width="200">Owner</th>
            </tr>
        </thead>
        <tbody id="assetsTableBody"></tbody>
    </table>

</div>

<script>
    const dummyAssets = [
        { assetId: 1, assetName: "Laptop", description: "Dell XPS 13", quantity: 2, owner: "admin01" },
        { assetId: 2, assetName: "Monitor", description: "27 inch LG", quantity: 1, owner: "josh123" },
        { assetId: 3, assetName: "Keyboard", description: "Mechanical keyboard", quantity: 3, owner: "mary88" }
    ];

    function loadAssets() {
        const body = document.getElementById("assetsTableBody");
        body.innerHTML = "";

        dummyAssets.forEach(asset => {
            const row = document.createElement("tr");

            row.innerHTML = `
                <td>${asset.assetId}</td>
                <td>${asset.assetName}</td>
                <td>${asset.description}</td>
                <td>${asset.quantity}</td>
                <td>${asset.owner}</td>
            `;

            body.appendChild(row);
        });
    }

    window.onload = loadAssets;
</script>