@{
    ViewData["Title"] = "Admin - Users";
}

<style>
    .admin-page {
        font-family: Arial, sans-serif;
    }

    .admin-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .admin-title {
        margin: 0;
        color: #333;
    }

    .back-button {
        padding: 10px 16px;
        background: #4a90e2;
        color: white;
        text-decoration: none;
        border-radius: 6px;
    }

        .back-button:hover {
            background-color: #357bd8;
            color: white;
        }

    .admin-table {
        width: 100%;
        border-collapse: collapse;
        background: white;
    }

        .admin-table th,
        .admin-table td {
            padding: 12px;
            border-bottom: 1px solid #ddd;
            text-align: left;
        }

        .admin-table th {
            background-color: #f5f6f8;
        }

    .role-badge {
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 13px;
        font-weight: bold;
        display: inline-block;
    }

    .role-admin {
        background-color: #ffe0e0;
        color: #b02a37;
    }

    .role-user {
        background-color: #e0ecff;
        color: #1f4f9f;
    }
</style>

<div class="admin-page">

    <div class="admin-header">
        <h2 class="admin-title">Users</h2>

        <a asp-controller="Admin" asp-action="Index" class="back-button">
            Back
        </a>
    </div>

    <table class="admin-table">
        <thead>
            <tr>
                <th width="180">User ID</th>
                <th width="220">Username</th>
                <th width="320">Email</th>
                <th width="150">Role</th>
            </tr>
        </thead>
        <tbody id="usersTableBody"></tbody>
    </table>

</div>

<script>
    const dummyUsers = [
        { userId: 1, username: "admin01", email: "admin01@example.com", role: "Admin" },
        { userId: 2, username: "josh123", email: "josh123@example.com", role: "User" },
        { userId: 3, username: "mary88", email: "mary88@example.com", role: "User" }
    ];

    function loadUsers() {
        const body = document.getElementById("usersTableBody");
        body.innerHTML = "";

        dummyUsers.forEach(user => {
            const roleClass = user.role === "Admin" ? "role-admin" : "role-user";

            const row = document.createElement("tr");
            row.innerHTML = `
                <td>${user.userId}</td>
                <td>${user.username}</td>
                <td>${user.email}</td>
                <td><span class="role-badge ${roleClass}">${user.role}</span></td>
            `;

            body.appendChild(row);
        });
    }

    window.onload = loadUsers;
</script>