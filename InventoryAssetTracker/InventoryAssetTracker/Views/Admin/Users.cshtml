@{
    ViewData["Title"] = "Admin - Users";
}

<style>
    .admin-page {
        font-family: Arial, sans-serif;
    }

    .admin-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
    }

    .admin-title {
        margin: 0;
        color: #1f2937;
        font-size: 2rem;
        font-weight: 700;
    }

    .back-button,
    .action-button {
        padding: 10px 18px;
        background: #4a90e2;
        color: white;
        text-decoration: none;
        border-radius: 8px;
        border: none;
        cursor: pointer;
        font-size: 14px;
        font-weight: 600;
        transition: background-color 0.2s ease, transform 0.1s ease;
    }

        .back-button:hover,
        .action-button:hover {
            background-color: #357bd8;
            color: white;
        }

        .back-button:active,
        .action-button:active {
            transform: translateY(1px);
        }

    .delete-button {
        background: #dc3545;
    }

        .delete-button:hover {
            background: #bb2d3b;
        }

    .admin-table-wrapper {
        background: white;
        border-radius: 14px;
        box-shadow: 0 4px 14px rgba(0, 0, 0, 0.08);
        overflow: hidden;
    }

    .admin-table {
        width: 100%;
        border-collapse: collapse;
        background: white;
    }

        .admin-table th,
        .admin-table td {
            padding: 16px 14px;
            border-bottom: 1px solid #e5e7eb;
            text-align: left;
            vertical-align: middle;
        }

        .admin-table th {
            background-color: #f8fafc;
            color: #374151;
            font-size: 15px;
            font-weight: 700;
        }

        .admin-table tr:last-child td {
            border-bottom: none;
        }

    .modern-input,
    .modern-select {
        width: 100%;
        max-width: 240px;
        padding: 10px 12px;
        border: 1px solid #cbd5e1;
        border-radius: 8px;
        background-color: #fff;
        font-size: 14px;
        color: #1f2937;
        outline: none;
        transition: border-color 0.2s ease, box-shadow 0.2s ease;
        box-sizing: border-box;
    }

        .modern-input:focus,
        .modern-select:focus {
            border-color: #4a90e2;
            box-shadow: 0 0 0 3px rgba(74, 144, 226, 0.15);
        }

    .actions-cell {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .status-message {
        margin-top: 20px;
        padding: 14px 16px;
        border-radius: 10px;
        display: none;
        font-size: 15px;
        font-weight: 500;
    }
</style>

<div class="admin-page">

    <div class="admin-header">
        <h2 class="admin-title">Users</h2>

        <a asp-controller="Admin" asp-action="Index" class="back-button">
            Back
        </a>
    </div>

    <div class="admin-table-wrapper">
        <table class="admin-table">
            <thead>
                <tr>
                    <th width="140">User ID</th>
                    <th width="260">Username</th>
                    <th width="320">Email</th>
                    <th width="180">Role</th>
                    <th width="220">Actions</th>
                </tr>
            </thead>
            <tbody id="usersTableBody"></tbody>
        </table>
    </div>
    <div id="statusMessage" style="margin: 15px 0; padding: 10px; border-radius: 6px; display: none;"></div>
</div>

<script>
    function showMessage(message, isSuccess) {
        const box = document.getElementById("statusMessage");
        box.textContent = message;
        box.style.display = "block";
        box.style.backgroundColor = isSuccess ? "#e8f5e9" : "#fdecea";
        box.style.color = isSuccess ? "#2e7d32" : "#b71c1c";
        box.style.border = isSuccess
            ? "1px solid #81c784"
            : "1px solid #ef9a9a";
    }

    async function loadUsers() {
        const body = document.getElementById("usersTableBody");
        body.innerHTML = "";

        const response = await fetch("/api/admin/users");

        if (!response.ok) {
            body.innerHTML = `<tr><td colspan="5">Failed to load users.</td></tr>`;
            return;
        }

        const users = await response.json();

        users.forEach(user => {
            const row = document.createElement("tr");
            row.innerHTML = `
                    <td>${user.userId}</td>
                    <td>
                        <input type="text" value="${user.username}" id="username-${user.userId}" class="modern-input" />
                    </td>
                    <td>
                        <input type="email" value="${user.email}" id="email-${user.userId}" class="modern-input" />
                    </td>
                    <td>
                        <select id="role-${user.userId}" class="modern-select">
                            <option value="User" ${user.role === "User" ? "selected" : ""}>User</option>
                            <option value="Admin" ${user.role === "Admin" ? "selected" : ""}>Admin</option>
                        </select>
                    </td>
                    <td>
                        <div class="actions-cell">
                            <button type="button" class="action-button" onclick="updateUser(${user.userId})">Save</button>
                            <button type="button" class="action-button delete-button" onclick="deleteUser(${user.userId})">Delete</button>
                        </div>
                    </td>
                `;

            body.appendChild(row);
        });
    }

    async function updateUser(userId) {
        const payload = {
            username: document.getElementById(`username-${userId}`).value,
            email: document.getElementById(`email-${userId}`).value,
            role: document.getElementById(`role-${userId}`).value
        };

        const response = await fetch(`/api/admin/users/${userId}`, {
            method: "PUT",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload)
        });

        const result = await response.json();
        showMessage(result.message || "Update finished.", response.ok);

        if (response.ok) {
            loadUsers();
        }
    }

    async function deleteUser(userId) {
        const response = await fetch(`/api/admin/users/${userId}`, {
            method: "DELETE"
        });

        const result = await response.json();
        showMessage(result.message || "Delete finished.", response.ok);

        if (response.ok) {
            loadUsers();
        }
    }

    window.onload = loadUsers;
</script>