@*
    FILE : Logs.cshtml
    PROGRAMMER : Name(s): Josiah Williams, Jeff, Gao Ricardo
    DESCRIPTION : Displays the admin page for viewing system log records.
*@
@{
    ViewData["Title"] = "Admin - Logs";
}

<style>
    .admin-page {
        font-family: Arial, sans-serif;
    }

    .admin-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
    }

    .admin-title {
        margin: 0;
        color: #1f2937;
        font-size: 2rem;
        font-weight: 700;
    }

    .back-button {
        padding: 10px 18px;
        background: #4a90e2;
        color: white;
        text-decoration: none;
        border-radius: 8px;
        border: none;
        cursor: pointer;
        font-size: 14px;
        font-weight: 600;
        transition: 0.2s;
    }

        .back-button:hover {
            background-color: #357bd8;
            color: white;
        }

    .admin-table-wrapper {
        background: white;
        border-radius: 14px;
        box-shadow: 0 4px 14px rgba(0, 0, 0, 0.08);
        overflow: hidden;
    }

    .admin-table {
        width: 100%;
        border-collapse: collapse;
    }

        .admin-table th,
        .admin-table td {
            padding: 16px 14px;
            border-bottom: 1px solid #e5e7eb;
            text-align: left;
            vertical-align: top;
        }

        .admin-table th {
            background-color: #f8fafc;
            color: #374151;
            font-size: 15px;
            font-weight: 700;
        }

        .admin-table tr:last-child td {
            border-bottom: none;
        }

    .log-action {
        font-weight: 700;
        color: #1f2937;
    }

    .log-user {
        color: #1f4f9f;
        font-weight: 600;
    }

    .log-time {
        color: #6b7280;
        white-space: nowrap;
    }

    .empty-row {
        color: #6b7280;
        text-align: center;
        padding: 24px;
    }
</style>

<div class="admin-page">

    <div class="admin-header">
        <h2 class="admin-title">Audit Logs</h2>

        <a asp-controller="Admin" asp-action="Index" class="back-button">
            Back
        </a>
    </div>

    <div class="admin-table-wrapper">
        <table class="admin-table">
            <thead>
                <tr>
                    <th width="180">Action</th>
                    <th width="320">Details</th>
                    <th width="180">User</th>
                    <th width="180">Created At</th>
                </tr>
            </thead>
            <tbody id="logsTableBody"></tbody>
        </table>
    </div>

</div>

<script>
    async function loadLogs() {
        const body = document.getElementById("logsTableBody");
        body.innerHTML = "";

        const response = await fetch("/api/admin/logs");

        if (!response.ok) {
            body.innerHTML = `<tr><td colspan="4" class="empty-row">Failed to load logs.</td></tr>`;
            return;
        }

        const logs = await response.json();

        if (logs.length === 0) {
            body.innerHTML = `<tr><td colspan="4" class="empty-row">No logs found.</td></tr>`;
            return;
        }

        logs.forEach(log => {
            const createdAt = new Date(log.createdAt).toLocaleString();

            const row = document.createElement("tr");
            row.innerHTML = `
                    <td class="log-action">${log.action}</td>
                    <td>${log.details}</td>
                    <td class="log-user">${log.username}</td>
                    <td class="log-time">${createdAt}</td>
                `;

            body.appendChild(row);
        });
    }

    window.onload = loadLogs;
</script>
