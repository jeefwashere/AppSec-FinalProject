@{
    ViewData["Title"] = "Admin - Logs";
}

<style>
    .admin-page {
        font-family: Arial, sans-serif;
    }

    .admin-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .admin-title {
        margin: 0;
        color: #333;
    }

    .back-button {
        padding: 10px 16px;
        background: #4a90e2;
        color: white;
        text-decoration: none;
        border-radius: 6px;
    }

        .back-button:hover {
            background-color: #357bd8;
            color: white;
        }

    .admin-table {
        width: 100%;
        border-collapse: collapse;
        background: white;
    }

        .admin-table th,
        .admin-table td {
            padding: 12px;
            border-bottom: 1px solid #ddd;
            text-align: left;
            vertical-align: top;
        }

        .admin-table th {
            background-color: #f5f6f8;
        }

    .log-action {
        font-weight: bold;
        color: #333;
    }

    .log-user {
        color: #1f4f9f;
        font-weight: 600;
    }

    .log-time {
        color: #666;
        white-space: nowrap;
    }
</style>

<div class="admin-page">

    <div class="admin-header">
        <h2 class="admin-title">Audit Logs</h2>

        <a asp-controller="Admin" asp-action="Index" class="back-button">
            Back
        </a>
    </div>

    <table class="admin-table">
        <thead>
            <tr>
                <th width="180">Action</th>
                <th width="320">Details</th>
                <th width="180">User</th>
                <th width="180">Created At</th>
            </tr>
        </thead>
        <tbody id="logsTableBody"></tbody>
    </table>

</div>

<script>
    const dummyLogs = [
        {
            action: "LOGIN_SUCCESS",
            details: "User logged in successfully.",
            username: "admin01",
            createdAt: "2026-04-13 09:15 AM"
        },
        {
            action: "ASSET_CREATED",
            details: "Created asset: Laptop.",
            username: "josh123",
            createdAt: "2026-04-13 09:40 AM"
        },
        {
            action: "PROFILE_PHOTO_UPLOAD",
            details: "Uploaded a new profile photo.",
            username: "mary88",
            createdAt: "2026-04-13 10:05 AM"
        },
        {
            action: "ASSET_DELETED",
            details: "Deleted asset: Keyboard.",
            username: "admin01",
            createdAt: "2026-04-13 10:30 AM"
        }
    ];

    function loadLogs() {
        const body = document.getElementById("logsTableBody");
        body.innerHTML = "";

        dummyLogs.forEach(log => {
            const row = document.createElement("tr");

            row.innerHTML = `
                <td class="log-action">${log.action}</td>
                <td>${log.details}</td>
                <td class="log-user">${log.username}</td>
                <td class="log-time">${log.createdAt}</td>
            `;

            body.appendChild(row);
        });
    }

    window.onload = loadLogs;
</script>