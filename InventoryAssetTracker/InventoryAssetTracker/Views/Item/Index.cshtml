@*
    FILE : Index.cshtml
    PROGRAMMER : Name(s): Josiah Williams, Jeff, Gao Ricardo
    DESCRIPTION : Displays the page for listing and managing user items.
*@
@{
    ViewData["Title"] = "My Assets";
}

<style>
    .asset-page {
        font-family: Arial, sans-serif;
    }

    .asset-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
    }

    .asset-title {
        margin: 0;
        color: #1f2937;
        font-size: 2rem;
        font-weight: 700;
    }

    .add-button,
    .action-button {
        padding: 10px 18px;
        background: #4a90e2;
        color: white;
        text-decoration: none;
        border-radius: 8px;
        border: none;
        cursor: pointer;
        font-size: 14px;
        font-weight: 600;
        transition: background-color 0.2s ease, transform 0.1s ease;
        display: inline-block;
    }

    .add-button:hover,
    .action-button:hover {
        background-color: #357bd8;
        color: white;
    }

    .add-button:active,
    .action-button:active {
        transform: translateY(1px);
    }

    .delete-button {
        background: #dc3545;
    }

    .delete-button:hover {
        background: #bb2d3b;
    }

    .search-box {
        margin-bottom: 20px;
        max-width: 500px;
    }

    .search-input {
        width: 70%;
        padding: 10px 12px;
        border: 1px solid #cbd5e1;
        border-radius: 8px;
        font-size: 14px;
        box-sizing: border-box;
    }

    .search-input:focus {
        outline: none;
        border-color: #4a90e2;
        box-shadow: 0 0 0 3px rgba(74, 144, 226, 0.15);
    }

    .search-button {
        padding: 10px 18px;
        border: none;
        border-radius: 8px;
        background-color: #4a90e2;
        color: white;
        cursor: pointer;
        margin-left: 8px;
        font-size: 14px;
        font-weight: 600;
        transition: background-color 0.2s ease, transform 0.1s ease;
    }

    .search-button:hover {
        background-color: #357bd8;
    }

    .search-button:active {
        transform: translateY(1px);
    }

    .asset-table-wrapper {
        background: white;
        border-radius: 14px;
        box-shadow: 0 4px 14px rgba(0, 0, 0, 0.08);
        overflow: hidden;
    }

    .asset-table {
        width: 100%;
        border-collapse: collapse;
        background: white;
    }

    .asset-table th,
    .asset-table td {
        padding: 16px 14px;
        border-bottom: 1px solid #e5e7eb;
        text-align: left;
        vertical-align: middle;
    }

    .asset-table th {
        background-color: #f8fafc;
        color: #374151;
        font-size: 15px;
        font-weight: 700;
    }

    .asset-table tr:last-child td {
        border-bottom: none;
    }

    .action-wrap {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .empty-message {
        margin-top: 20px;
        color: #666;
    }

    .status-message {
        margin-top: 20px;
        padding: 14px 16px;
        border-radius: 10px;
        display: none;
        font-size: 15px;
        font-weight: 500;
    }

    .modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(15, 23, 42, 0.45);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
    }

    .modal-box {
        width: 100%;
        max-width: 420px;
        background: white;
        border-radius: 14px;
        box-shadow: 0 12px 30px rgba(0, 0, 0, 0.18);
        padding: 24px;
    }

    .modal-title {
        margin: 0 0 10px 0;
        color: #1f2937;
        font-size: 1.3rem;
        font-weight: 700;
    }

    .modal-text {
        margin: 0 0 18px 0;
        color: #4b5563;
        line-height: 1.5;
    }

    .modal-actions {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
    }

    .cancel-button {
        background: #6b7280;
    }

        .cancel-button:hover {
            background: #4b5563;
        }

    .danger-button {
        background: #dc3545;
    }

        .danger-button:hover {
            background: #bb2d3b;
        }
</style>

<div class="asset-page">

    <div class="asset-header">
        <h2 class="asset-title">My Assets</h2>
        <a asp-controller="Item" asp-action="Add" class="add-button">Add Asset</a>
    </div>

    <div class="search-box">
        <input type="text" id="searchTerm" class="search-input" placeholder="Search assets..." />
        <button type="button" class="search-button" onclick="loadAssets()">Search</button>
    </div>

    <div class="asset-table-wrapper">
        <table class="asset-table" id="assetTable" style="display:none;">
            <thead>
                <tr>
                    <th width="250">Asset Name</th>
                    <th width="350">Description</th>
                    <th width="120">Quantity</th>
                    <th width="260">Actions</th>
                </tr>
            </thead>
            <tbody id="assetTableBody"></tbody>
        </table>
    </div>

    <p class="empty-message" id="emptyMessage" style="display:none;">
        No assets found. Add your first asset.
    </p>

    <div id="statusMessage" class="status-message"></div>
</div>

<div id="deleteConfirmModal" class="modal-overlay" style="display:none;">
    <div class="modal-box">
        <h3 class="modal-title">Delete Asset</h3>
        <p id="deleteConfirmText" class="modal-text"></p>

        <div class="modal-actions">
            <button type="button" class="action-button danger-button" id="confirmDeleteButton">Delete</button>
            <button type="button" class="action-button cancel-button" onclick="closeDeleteModal()">Cancel</button>
        </div>
    </div>
</div>

<script>
    let pendingDeleteAssetId = null;
    let pendingDeleteAssetName = "";

    function showMessage(message, isSuccess) {
        const box = document.getElementById("statusMessage");
        box.textContent = message;
        box.style.display = "block";
        box.style.backgroundColor = isSuccess ? "#e8f5e9" : "#fdecea";
        box.style.color = isSuccess ? "#2e7d32" : "#b71c1c";
        box.style.border = isSuccess
            ? "1px solid #81c784"
            : "1px solid #ef9a9a";
    }

    function openDeleteModal(assetId, assetName) {
        pendingDeleteAssetId = assetId;
        pendingDeleteAssetName = assetName;

        const text = document.getElementById("deleteConfirmText");
        text.textContent = `Are you sure you want to delete asset "${assetName}"? This action cannot be undone.`;

        const confirmButton = document.getElementById("confirmDeleteButton");
        confirmButton.onclick = confirmDeleteAsset;

        document.getElementById("deleteConfirmModal").style.display = "flex";
    }

    function closeDeleteModal() {
        pendingDeleteAssetId = null;
        pendingDeleteAssetName = "";
        document.getElementById("deleteConfirmModal").style.display = "none";
    }

    async function loadAssets() {
        const term = document.getElementById("searchTerm").value.trim();
        let url = "/api/itemapi";

        if (term.length > 0) {
            url = "/api/searchapi/search?term=" + encodeURIComponent(term);
        }

        const response = await fetch(url, {
            method: "GET",
            credentials: "same-origin"
        });

        if (!response.ok) {
            if (response.status === 401 || response.status === 403) {
                window.location.href = "/Account/Login";
                return;
            }

            showMessage("Failed to load assets.", false);
            return;
        }

        const assets = await response.json();

        const table = document.getElementById("assetTable");
        const body = document.getElementById("assetTableBody");
        const emptyMessage = document.getElementById("emptyMessage");

        body.innerHTML = "";

        if (!assets || assets.length === 0) {
            table.style.display = "none";
            emptyMessage.style.display = "block";
            return;
        }

        emptyMessage.style.display = "none";
        table.style.display = "table";

        assets.forEach(asset => {
            const safeAssetName = (asset.assetName ?? "").replace(/'/g, "\\'");

            const row = document.createElement("tr");

            row.innerHTML = `
                    <td>${asset.assetName ?? ""}</td>
                    <td>${asset.description ?? ""}</td>
                    <td>${asset.quantity ?? 0}</td>
                    <td>
                        <div class="action-wrap">
                            <a href="/Item/Details?id=${asset.assetId}" class="action-button">Details</a>
                            <a href="/Item/Update?id=${asset.assetId}" class="action-button">Update</a>
                            <button type="button" class="action-button delete-button"
                                onclick="openDeleteModal(${asset.assetId}, '${safeAssetName}')">Delete</button>
                        </div>
                    </td>
                `;

            body.appendChild(row);
        });
    }

    async function confirmDeleteAsset() {
        if (pendingDeleteAssetId === null) {
            return;
        }

        const response = await fetch("/api/itemapi/" + pendingDeleteAssetId, {
            method: "DELETE",
            credentials: "same-origin"
        });

        closeDeleteModal();

        if (!response.ok) {
            showMessage("Failed to delete asset.", false);
            return;
        }

        showMessage(`Asset "${pendingDeleteAssetName}" was deleted successfully.`, true);
        loadAssets();
    }

    window.onload = loadAssets;
</script>
