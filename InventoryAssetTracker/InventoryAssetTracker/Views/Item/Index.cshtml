@{
    ViewData["Title"] = "My Assets";
}

<style>
    .asset-page {
        font-family: Arial, sans-serif;
    }

    .asset-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .asset-title {
        margin: 0;
        color: #333;
    }

    .add-button {
        padding: 10px 16px;
        background: #4a90e2;
        color: white;
        text-decoration: none;
        border-radius: 6px;
    }

        .add-button:hover {
            background-color: #357bd8;
            color: white;
        }

    .search-box {
        margin-bottom: 20px;
        max-width: 500px;
    }

    .search-input {
        width: 70%;
        padding: 10px;
        border: 1px solid #ccc;
        border-radius: 6px;
    }

    .search-button {
        padding: 10px 16px;
        border: none;
        border-radius: 6px;
        background-color: #4a90e2;
        color: white;
        cursor: pointer;
        margin-left: 8px;
    }

        .search-button:hover {
            background-color: #357bd8;
        }

    .asset-table {
        width: 100%;
        border-collapse: collapse;
        background: white;
    }

        .asset-table th, .asset-table td {
            padding: 12px;
            border-bottom: 1px solid #ddd;
            text-align: left;
        }

        .asset-table th {
            background-color: #f5f6f8;
        }

    .action-wrap {
        display: flex;
        gap: 8px;
    }

    .action-button {
        padding: 6px 12px;
        background-color: #4a90e2;
        color: white;
        text-decoration: none;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        display: inline-block;
        font-size: 14px;
    }

        .action-button:hover {
            background-color: #357bd8;
            color: white;
        }

    .empty-message {
        margin-top: 20px;
        color: #666;
    }
</style>

<div class="asset-page">

    <div class="asset-header">
        <h2 class="asset-title">My Assets</h2>
        <a asp-controller="Item" asp-action="Add" class="add-button">Add Asset</a>
    </div>

    <div class="search-box">
        <input type="text" id="searchTerm" class="search-input" placeholder="Search assets..." />
        <button type="button" class="search-button" onclick="loadAssets()">Search</button>
    </div>

    <table class="asset-table" id="assetTable" style="display:none;">
        <thead>
            <tr>
                <th width="250">Asset Name</th>
                <th width="350">Description</th>
                <th width="120">Quantity</th>
                <th width="260">Actions</th>
            </tr>
        </thead>
        <tbody id="assetTableBody"></tbody>
    </table>

    <p class="empty-message" id="emptyMessage" style="display:none;">
        No assets found. Add your first asset.
    </p>
</div>

<script>
    async function loadAssets() {
        const term = document.getElementById("searchTerm").value.trim();
        let url = "/api/itemapi";

        if (term.length > 0) {
            url = "/api/searchapi/search?term=" + encodeURIComponent(term);
        }

        const response = await fetch(url, {
            method: "GET",
            credentials: "same-origin"
        });

        if (!response.ok) {
            if (response.status === 401 || response.status === 403) {
                window.location.href = "/Account/Login";
                return;
            }

            alert("Failed to load assets.");
            return;
        }

        const assets = await response.json();

        const table = document.getElementById("assetTable");
        const body = document.getElementById("assetTableBody");
        const emptyMessage = document.getElementById("emptyMessage");

        body.innerHTML = "";

        if (!assets || assets.length === 0) {
            table.style.display = "none";
            emptyMessage.style.display = "block";
            return;
        }

        emptyMessage.style.display = "none";
        table.style.display = "table";

        assets.forEach(asset => {
            const row = document.createElement("tr");

            row.innerHTML = `
                <td>${asset.assetName ?? ""}</td>
                <td>${asset.description ?? ""}</td>
                <td>${asset.quantity ?? 0}</td>
                <td>
                    <div class="action-wrap">
                        <a href="/Item/Details?id=${asset.assetId}" class="action-button">Details</a>
                        <a href="/Item/Update?id=${asset.assetId}" class="action-button">Update</a>
                        <button class="action-button" onclick="deleteAsset(${asset.assetId})">Delete</button>
                    </div>
                </td>
            `;

            body.appendChild(row);
        });
    }

    async function deleteAsset(assetId) {
        const confirmed = confirm("Are you sure you want to delete this asset?");
        if (!confirmed) {
            return;
        }

        const response = await fetch("/api/itemapi/" + assetId, {
            method: "DELETE",
            credentials: "same-origin"
        });

        if (!response.ok) {
            alert("Failed to delete asset.");
            return;
        }

        loadAssets();
    }

    window.onload = loadAssets;
</script>