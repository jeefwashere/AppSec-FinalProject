@*
    FILE : Update.cshtml
    PROGRAMMER : Name(s): Josiah Williams, Jeff, Gao Ricardo
    DESCRIPTION : Displays the page for updating an existing inventory item.
*@
@{
    ViewData["Title"] = "Update Asset";
    var assetId = ViewBag.AssetId;
}

<style>
    .update-card {
        max-width: 560px;
        margin: 80px auto;
        background-color: #ffffff;
        padding: 36px;
        border-radius: 14px;
        box-shadow: 0 4px 14px rgba(0, 0, 0, 0.10);
        font-family: Arial, sans-serif;
    }

    .update-title {
        text-align: center;
        margin-bottom: 30px;
        color: #1f2937;
        font-size: 2rem;
        font-weight: 700;
    }

    .update-container {
        width: 100%;
        max-width: 400px;
        margin: 0 auto;
    }

    .update-row {
        margin-bottom: 18px;
    }

    .update-label {
        display: block;
        margin-bottom: 8px;
        color: #1f2937;
        font-size: 15px;
    }

    .update-input {
        width: 100%;
        padding: 12px 14px;
        border: 1px solid #cbd5e1;
        border-radius: 10px;
        font-size: 15px;
        box-sizing: border-box;
        transition: border-color 0.2s ease, box-shadow 0.2s ease;
    }

        .update-input:focus {
            outline: none;
            border-color: #4a90e2;
            box-shadow: 0 0 0 3px rgba(74, 144, 226, 0.15);
        }

    .update-actions {
        margin-top: 20px;
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }

    .update-button,
    .back-button {
        width: 130px;
        padding: 10px 0;
        border: 1px solid #4a90e2;
        background: #4a90e2;
        color: white;
        cursor: pointer;
        text-align: center;
        border-radius: 8px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        box-sizing: border-box;
        font-size: 15px;
        transition: background-color 0.2s ease;
    }

        .update-button:hover,
        .back-button:hover {
            background-color: #357bd8;
            color: white;
        }

        .update-button:disabled {
            background-color: #93b9e8;
            border-color: #93b9e8;
            cursor: not-allowed;
        }

    .message-box {
        margin-top: 16px;
        padding: 12px 14px;
        border-radius: 8px;
        display: none;
    }

    .message-error {
        display: block;
        background-color: #fdecea;
        color: #b71c1c;
        border: 1px solid #ef9a9a;
    }

    .message-success {
        display: block;
        background-color: #e8f5e9;
        color: #2e7d32;
        border: 1px solid #81c784;
    }
</style>

<div class="update-card">
    <h2 class="update-title">Update Asset</h2>

    <div class="update-container">
        <input type="hidden" id="assetId" value="@assetId" />

        <div class="update-row">
            <label class="update-label" for="itemName">Asset Name</label>
            <input id="itemName" class="update-input" />
        </div>

        <div class="update-row">
            <label class="update-label" for="description">Description</label>
            <input id="description" class="update-input" />
        </div>

        <div class="update-row">
            <label class="update-label" for="quantity">Quantity</label>
            <input id="quantity" type="number" min="0" class="update-input" />
        </div>

        <div class="update-actions">
            <button type="button" id="updateAssetButton" class="update-button" onclick="updateAsset()">Update Asset</button>
            <a asp-action="Index" asp-controller="Item" class="back-button">Back</a>
        </div>

        <div id="messageBox" class="message-box"></div>
    </div>
</div>

<script>
    let isUpdating = false;

    function showMessage(message, isSuccess) {
        const messageBox = document.getElementById("messageBox");
        messageBox.textContent = message;
        messageBox.className = isSuccess
            ? "message-box message-success"
            : "message-box message-error";
    }

    async function loadAsset() {
        const assetId = document.getElementById("assetId").value;

        const response = await fetch("/api/itemapi/" + assetId, {
            method: "GET",
            credentials: "same-origin"
        });

        if (!response.ok) {
            if (response.status === 401 || response.status === 403) {
                window.location.href = "/Account/Login";
                return;
            }

            window.location.href = "/Item/Index";
            return;
        }

        const asset = await response.json();

        document.getElementById("itemName").value = asset.assetName ?? "";
        document.getElementById("description").value = asset.description ?? "";
        document.getElementById("quantity").value = asset.quantity ?? 0;
    }

    async function updateAsset() {
        if (isUpdating) {
            return;
        }

        const updateButton = document.getElementById("updateAssetButton");
        const assetId = parseInt(document.getElementById("assetId").value);
        const itemName = document.getElementById("itemName").value.trim();
        const description = document.getElementById("description").value.trim();
        const quantityValue = document.getElementById("quantity").value;
        const quantity = parseInt(quantityValue);

        const messageBox = document.getElementById("messageBox");
        messageBox.className = "message-box";
        messageBox.textContent = "";

        if (!itemName) {
            showMessage("Asset name is required.", false);
            return;
        }

        if (isNaN(quantity) || quantity < 0) {
            showMessage("Quantity must be 0 or greater.", false);
            return;
        }

        isUpdating = true;
        updateButton.disabled = true;
        updateButton.textContent = "Updating...";

        const requestBody = {
            itemID: assetId,
            itemName: itemName,
            description: description,
            quantity: quantity
        };

        let shouldKeepDisabled = false;

        try {
            const response = await fetch("/api/itemapi/" + assetId, {
                method: "PUT",
                headers: {
                    "Content-Type": "application/json"
                },
                credentials: "same-origin",
                body: JSON.stringify(requestBody)
            });

            if (!response.ok) {
                if (response.status === 401 || response.status === 403) {
                    window.location.href = "/Account/Login";
                    return;
                }

                let errorText = "Failed to update asset.";

                try {
                    const errorData = await response.json();
                    if (errorData.message) {
                        errorText = errorData.message;
                    }
                } catch {
                }

                showMessage(errorText, false);
                return;
            }

            showMessage("Asset updated successfully.", true);
            shouldKeepDisabled = true;

            setTimeout(() => {
                window.location.href = "/Item/Index";
            }, 700);
        } finally {
            if (!shouldKeepDisabled) {
                isUpdating = false;
                updateButton.disabled = false;
                updateButton.textContent = "Update Asset";
            }
        }
    }

    window.onload = loadAsset;
</script>