@using Microsoft.AspNetCore.Mvc.ModelBinding
@model InventoryAssetTracker.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Register";
}

<style>
    .account-card {
        max-width: 560px;
        margin: 80px auto;
        background-color: #ffffff;
        padding: 36px;
        border-radius: 14px;
        box-shadow: 0 4px 14px rgba(0, 0, 0, 0.10);
        font-family: Arial, sans-serif;
    }

    .account-title {
        text-align: center;
        margin-bottom: 30px;
        color: #1f2937;
        font-size: 2rem;
        font-weight: 700;
    }

    .account-container {
        width: 100%;
        max-width: 400px;
        margin: 0 auto;
    }

    .form-group {
        margin-bottom: 18px;
    }

    .form-label {
        display: block;
        margin-bottom: 8px;
        color: #1f2937;
        font-size: 15px;
    }

    .form-input {
        width: 100%;
        padding: 12px 14px;
        border: 1px solid #cbd5e1;
        border-radius: 10px;
        font-size: 15px;
        box-sizing: border-box;
        transition: border-color 0.2s ease, box-shadow 0.2s ease;
    }

    .form-input:focus {
        outline: none;
        border-color: #4a90e2;
        box-shadow: 0 0 0 3px rgba(74, 144, 226, 0.15);
    }

    .button-row {
        margin-top: 20px;
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }

    .form-button,
    .back-button {
        width: 130px;
        padding: 10px 0;
        border: 1px solid #4a90e2;
        background: #4a90e2;
        color: white;
        cursor: pointer;
        text-align: center;
        border-radius: 8px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        box-sizing: border-box;
        font-size: 15px;
        transition: background-color 0.2s ease;
    }

    .form-button:hover,
    .back-button:hover {
        background-color: #357bd8;
        color: white;
    }

    .error-box {
        margin-top: 16px;
        padding: 12px 14px;
        border-radius: 8px;
        background-color: #fdecea;
        color: #b71c1c;
        border: 1px solid #ef9a9a;
        font-weight: 600;
    }

    .error-box p {
        margin: 0 0 6px 0;
    }

    .error-box p:last-child {
        margin-bottom: 0;
    }
</style>

<div class="account-card">
    <h2 class="account-title">Create Account</h2>

    <form asp-controller="Account" asp-action="Register" method="post">
        @Html.AntiForgeryToken()

        <div class="form-group">
            <label asp-for="Username" class="form-label">Username</label>
            <input asp-for="Username" class="form-input" />
        </div>

        <div class="form-group">
            <label asp-for="Email" class="form-label">Email</label>
            <input asp-for="Email" class="form-input" />
        </div>

        <div class="form-group">
            <label asp-for="Password" class="form-label">Password</label>
            <input asp-for="Password" type="password" class="form-input" />
        </div>

        <div class="button-row">
            <button type="submit" class="form-button">Register</button>
            <a asp-controller="Account" asp-action="Login" class="form-button">Back</a>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="error-box">
                @foreach (ModelError error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <p>@error.ErrorMessage</p>
                }
            </div>
        }
    </form>
</div>