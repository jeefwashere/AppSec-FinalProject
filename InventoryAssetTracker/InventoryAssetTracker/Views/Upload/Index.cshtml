@{
	ViewData["Title"] = "Upload File";
}

<style>
    .upload-card {
        max-width: 560px;
        margin: 80px auto;
        background-color: #ffffff;
        padding: 36px;
        border-radius: 14px;
        box-shadow: 0 4px 14px rgba(0, 0, 0, 0.10);
        font-family: Arial, sans-serif;
    }

    .upload-title {
        text-align: center;
        margin-bottom: 30px;
        color: #1f2937;
        font-size: 2rem;
        font-weight: 700;
    }

    .upload-container {
        width: 100%;
        max-width: 400px;
        margin: 0 auto;
    }

    .upload-row {
        margin-bottom: 18px;
    }

    .upload-label {
        display: block;
        margin-bottom: 8px;
        color: #1f2937;
        font-size: 15px;
    }

    .upload-input {
        width: 100%;
        padding: 12px 14px;
        border: 1px solid #cbd5e1;
        border-radius: 10px;
        font-size: 15px;
        box-sizing: border-box;
        background-color: #ffffff;
        transition: border-color 0.2s ease, box-shadow 0.2s ease;
    }

    .upload-input:focus {
        outline: none;
        border-color: #4a90e2;
        box-shadow: 0 0 0 3px rgba(74, 144, 226, 0.15);
    }

    .upload-actions {
        margin-top: 20px;
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }

    .upload-button,
    .back-button {
        width: 130px;
        padding: 10px 0;
        border: 1px solid #4a90e2;
        background: #4a90e2;
        color: white;
        cursor: pointer;
        text-align: center;
        border-radius: 8px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        box-sizing: border-box;
        font-size: 15px;
        transition: background-color 0.2s ease;
    }

        .upload-button:hover,
        .back-button:hover {
            background-color: #357bd8;
            color: white;
        }

    .message-box {
        margin-top: 16px;
        padding: 12px 14px;
        border-radius: 8px;
        display: none;
        font-weight: 600;
    }

    .message-error {
        display: block;
        background-color: #fdecea;
        color: #b71c1c;
        border: 1px solid #ef9a9a;
    }

    .message-success {
        display: block;
        background-color: #e8f5e9;
        color: #2e7d32;
        border: 1px solid #81c784;
    }
</style>

<div class="upload-card">
	<h2 class="upload-title">Upload File</h2>

	<div class="upload-row">
		<input type="file" id="fileInput" class="upload-input" />
	</div>

	<div class="upload-actions">
		<button type="button" class="upload-button" onclick="uploadFile()">Upload</button>
		<a asp-controller="Account" asp-action="Profile" class="back-button">Back</a>
	</div>

	<div id="messageBox"></div>
</div>

<script>
	async function uploadFile() {
		const fileInput = document.getElementById("fileInput");
		const messageBox = document.getElementById("messageBox");

		messageBox.innerHTML = "";

		if (fileInput.files.length === 0) {
			messageBox.innerHTML = '<p class="upload-error">Please select a file.</p>';
			return;
		}

		const file = fileInput.files[0];

		// Optional basic client validation
		if (file.size > 5 * 1024 * 1024) { // 5MB limit
			messageBox.innerHTML = '<p class="upload-error">File too large (max 5MB).</p>';
			return;
		}

		const formData = new FormData();
		formData.append("file", file);

		const response = await fetch("/api/uploadapi/profile-photo", {
			method: "POST",
			credentials: "same-origin",
			body: formData
		});

		if (!response.ok) {
			if (response.status === 401 || response.status === 403) {
				window.location.href = "/Account/Login";
				return;
			}

			let errorText = "Upload failed.";

			try {
				const data = await response.json();
				if (data.message) {
					errorText = data.message;
				}
			} catch {
			}

			messageBox.innerHTML = `<p class="upload-error">${errorText}</p>`;
			return;
		}

		const result = await response.json();

		if (result.photoPath) {
			sessionStorage.setItem("uploadedPhoto", result.photoPath);
		}

		messageBox.innerHTML = '<p class="upload-success">Upload successful!</p>';

		setTimeout(() => {
			window.location.href = "/Account/Profile";
		}, 700);
	}
</script>