<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Inventory Tracker</title>

    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background-color: #f4f6f8;
        }

        .navbar {
            background-color: #4a90e2;
            padding: 12px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .nav-left,
        .nav-right {
            display: flex;
            gap: 12px;
            align-items: center;
        }

        .nav-link {
            color: white;
            text-decoration: none;
            padding: 8px 12px;
            border-radius: 6px;
        }

            .nav-link:hover {
                background-color: #357bd8;
            }

        .container {
            padding: 20px;
        }

        .footer {
            text-align: center;
            padding: 15px;
            margin-top: 40px;
            color: #777;
        }

        .role-debug {
            color: #fff;
            font-size: 12px;
            margin-left: 10px;
        }
    </style>
</head>

<body>

    <!-- NAVBAR -->
    <div class="navbar">

        <!-- LEFT SIDE -->
        <div class="nav-left">
            <a asp-controller="Home" asp-action="Index" class="nav-link">Home</a>
            <a asp-controller="Item" asp-action="Index" class="nav-link">Assets</a>
        </div>

        <!-- RIGHT SIDE -->
        <div class="nav-right">

            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <a asp-controller="Account" asp-action="Profile" class="nav-link">Profile</a>

                <!-- Admin link only for Admin users -->
                @if (User.IsInRole("Admin"))
                {
                    <a asp-controller="Admin" asp-action="Index" class="nav-link">Admin</a>
                }

                <!-- Logout -->
                <form asp-controller="Account" asp-action="Logout" method="post" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="nav-link" style="background:none;border:none;cursor:pointer;">
                        Logout
                    </button>
                </form>

               
            }
            else
            {
                <a asp-controller="Account" asp-action="Login" class="nav-link">Login</a>
                <a asp-controller="Account" asp-action="Register" class="nav-link">Register</a>
            }

        </div>
    </div>

    <!-- PAGE CONTENT -->
    <div class="container">
        @RenderBody()
    </div>

    <!-- FOOTER -->
    <div class="footer">
        &copy; 2026 Inventory Asset Tracker |
        <a asp-controller="Home" asp-action="Privacy" style="color:#4a90e2; text-decoration:none;">
            Privacy
        </a>
    </div>

</body>
</html>